# Vercel Blob — get from Vercel dashboard after adding Blob store
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx

# Shared secret between Next.js and the Render worker
API_SECRET=generate-a-random-secret-here

# Render worker URL (set after deploying worker)
WORKER_URL=https://vr180-worker.onrender.com

# Optional: cron endpoint protection
CRON_SECRET=generate-another-secret-here
